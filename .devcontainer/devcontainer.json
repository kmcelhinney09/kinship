{
  // devcontainer.json
  // VS Code Development Container configuration for Kinship project
  "name": "Kinship DevContainer",
  "dockerComposeFile": [
    "../docker-compose.yml"
  ],
  "service": "backend", // Attach VS Code to the backend container
  "workspaceFolder": "/app", // Set workspace folder inside the container
  "forwardPorts": [8000, 3000, 5432], // Forward backend, frontend, and DB ports
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python", // Python support
        "ms-python.django", // Django support
        "esbenp.prettier-vscode", // Prettier for code formatting
        "ms-azuretools.vscode-docker" // Docker extension
      ]
    }
  },
  "remoteUser": "vscode", // Use the non-root user
  "postCreateCommand": "pip install --user --upgrade pip"
}
