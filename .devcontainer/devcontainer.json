{
  "name": "Kinship Dev",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/kinship",

  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }

  },

  "runServices": ["app"],
  "mounts": [
    "source=${env:HOME}/.config/gcloud,target=/home/vscode/.config/gcloud,type=bind,consistency=cached"
  ],
  "containerEnv": {
    "CLOUDSDK_CONFIG": "/home/vscode/.config/gcloud"
  },
  
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.vscode-python-envs",
        "DavidAnson.vscode-markdownlint",
        "ms-python.debugpy",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "GitHub.copilot-chat",
        "GitHub.copilot",
        "dbaeumer.vscode-eslint",
        "google.gemini-cli-vscode-ide-companion"
      ]
    }
  },
  "forwardPorts": [8000, 5173, 8001],
  "postAttachCommand": "uvicorn backend.main:app --host 0.0.0.0 --port 8000 --reload &",
  "postCreateCommand": "npm install -g npm@latest && npm install -g @google/gemini-cli"
}